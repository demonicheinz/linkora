{
  "name": "linkora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --no-errors-on-unmatched",
    "format": "bun biome check --write --no-errors-on-unmatched",
    "typecheck": "tsc --noEmit",
    "lint-staged": "lint-staged",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "bun prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@base-ui/react": "^1.5.0",
